# virtuoso-bridge configuration
# Fill in VB_REMOTE_HOST and you're ready to go.

VB_REMOTE_HOST=
VB_REMOTE_USER=

# Jump host (only if your SSH path uses a bastion)
# VB_JUMP_HOST=
# VB_JUMP_USER=

# Port configuration (auto-assigned, override only if needed)
VB_REMOTE_PORT={remote_port}
VB_LOCAL_PORT={local_port}

# Spectre (fill when running simulations)
# VB_CADENCE_CSHRC=     # cshrc that sources Cadence tools on the remote machine
